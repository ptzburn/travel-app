{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev:app": "deno run --allow-env --allow-sys --allow-ffi --env-file --allow-net --allow-read --allow-write --allow-run vite --port 3040",
    "build": "deno run --allow-env --allow-read --allow-sys --allow-run --allow-ffi --env-file=.env.prod --allow-write vite build",
    "dev": "concurrently \"deno task dev:app\" \"docker compose up\"",
    "start": "deno run --allow-net --allow-read --allow-write --allow-ffi --allow-env --env-file=.env.prod --allow-sys ./.output/server/index.mjs",
    "db:generate": "deno -A --env-file npm:drizzle-kit@^1.0.0-beta.18-7eb39f0 generate",
    "db:migrate": "deno -A --env-file npm:drizzle-kit@^1.0.0-beta.18-7eb39f0 migrate",
    "db:studio": "deno -A --env-file --node-modules-dir npm:drizzle-kit@^1.0.0-beta.18-7eb39f0 studio --port 8000",
    "db-prod:migrate": "deno -A --env-file=.env.prod npm:drizzle-kit@^1.0.0-beta.18-7eb39f0 migrate",
    "db-prod:studio": "deno -A --node-modules-dir --env-file=.env.prod npm:drizzle-kit@^1.0.0-beta.18-7eb39f0 studio --port 8000",
    "check": "deno fmt --ignore=src/api/emails/templates ./src/ && deno lint ./src/ && deno check ./src/",
    "generate:email-types": "deno run --allow-read --allow-write src/api/emails/generate-types.ts"
  },
  "lint": {
    "rules": {
      "include": [
        "explicit-function-return-type",
        "eqeqeq",
        "camelcase",
        "guard-for-in",
        "no-inferrable-types",
        "no-slow-types",
        "verbatim-module-syntax",
        "single-var-declarator",
        "triple-slash-reference",
        "no-useless-rename",
        "no-self-compare",
        "no-throw-literal",
        "no-sync-fn-in-async-fn",
        "no-sparse-arrays",
        "no-console",
        "no-eval",
        "no-await-in-loop",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "explicit-module-boundary-types"
      ],
      "exclude": [
        "jsx-key"
      ],
      "tags": [
        "recommended",
        "jsx"
      ]
    },
    "plugins": [
      "jsr:@ayk/lint-import-order",
      "jsr:@ryu/deno-lint-plugin-tailwindcss"
    ]
  },
  "imports": {
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1015.0",
    "@iconify-json/bxl": "npm:@iconify-json/bxl@^1.2.4",
    "@iconify-json/fa7-brands": "npm:@iconify-json/fa7-brands@^1.2.2",
    "@iconify-json/logos": "npm:@iconify-json/logos@^1.2.11",
    "@iconify-json/lucide": "npm:@iconify-json/lucide@^1.2.98",
    "@iconify-json/simple-icons": "npm:@iconify-json/simple-icons@^1.2.77",
    "@solid-primitives/upload": "npm:@solid-primitives/upload@^0.1.4",
    "@types/slug": "npm:@types/slug@^5.0.9",
    "date-fns": "npm:date-fns@^4.1.0",
    "nanoid": "npm:nanoid@^5.1.7",
    "slug": "npm:slug@^11.0.1",
    "solid-qr-code": "npm:solid-qr-code@^0.1.11",
    "unplugin-icons": "npm:unplugin-icons@^23.0.1",
    "~/": "./src/",
    "@nerimity/solid-turnstile": "npm:@nerimity/solid-turnstile@^1.1.0",
    "@ark-ui/solid": "npm:@ark-ui/solid@^5.34.1",
    "@better-auth/drizzle-adapter": "npm:@better-auth/drizzle-adapter@^1.6.0",
    "@better-auth/passkey": "npm:@better-auth/passkey@^1.5.5",
    "@corvu/calendar": "npm:@corvu/calendar@^0.1.2",
    "@corvu/drawer": "npm:@corvu/drawer@^0.2.4",
    "@corvu/otp-field": "npm:@corvu/otp-field@^0.1.4",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.6",
    "@hono/zod-openapi": "npm:@hono/zod-openapi@^1.2.2",
    "@kobalte/core": "npm:@kobalte/core@^0.13.11",
    "@kobalte/tailwindcss": "npm:@kobalte/tailwindcss@^0.9.0",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "@scalar/hono-api-reference": "npm:@scalar/hono-api-reference@^0.10.3",
    "@seven.io/client": "npm:@seven.io/client@^5.5.1",
    "@solidjs/meta": "npm:@solidjs/meta@^0.29.4",
    "@solidjs/router": "npm:@solidjs/router@^0.15.4",
    "@solidjs/start": "npm:@solidjs/start@^2.0.0-alpha.2",
    "@solidjs/vite-plugin-nitro-2": "npm:@solidjs/vite-plugin-nitro-2@^0.1.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "@tanstack/solid-form": "npm:@tanstack/solid-form@^1.28.5",
    "better-auth": "npm:better-auth@^1.6.0",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "clsx": "npm:clsx@^2.1.1",
    "cmdk-solid": "npm:cmdk-solid@^1.1.2",
    "concurrently": "npm:concurrently@^9.2.1",
    "drizzle-kit": "npm:drizzle-kit@^1.0.0-beta.18-7eb39f0",
    "drizzle-orm": "npm:drizzle-orm@^1.0.0-beta.18-7eb39f0",
    "drizzle-zod": "npm:drizzle-zod@^0.8.3",
    "embla-carousel-solid": "npm:embla-carousel-solid@^8.6.0",
    "hono": "npm:hono@^4.12.8",
    "hono-pino": "npm:hono-pino@^0.10.3",
    "hono-rate-limiter": "npm:hono-rate-limiter@^0.5.3",
    "lefthook": "npm:lefthook@^2.1.4",
    "pino": "npm:pino@^10.3.1",
    "pino-pretty": "npm:pino-pretty@^13.1.3",
    "resend": "npm:resend@^6.9.3",
    "solid-js": "npm:solid-js@^1.9.11",
    "solid-sonner": "npm:solid-sonner@^0.3.1",
    "tailwind-merge": "npm:tailwind-merge@^3.5.0",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "tailwindcss-animate": "npm:tailwindcss-animate@^1.0.7",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "vite": "npm:vite@^7.3.1",
    "zod": "npm:zod@^4.3.6"
  },
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext",
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "types": [
      "vite/client",
      "unplugin-icons/types/solid"
    ]
  },
  "allowScripts": ["npm:lefthook"]
}
